# Server
PORT=8787
AUTH_USER=replace-me
AUTH_PASSWORD=replace-me
ADMIN_USER=replace-me
ADMIN_PASSWORD=replace-me
# Required for signing the portal session cookie. Use a long random value.
APP_SESSION_SECRET=replace-me-with-a-random-secret
APP_SESSION_TTL_DAYS=30
APP_SESSION_COOKIE_NAME=sooka_portal_session
APP_LOG_FILE=.logs/portal.log
APP_LOG_LEVEL=debug
APP_JOBS_FILE=.data/jobs.jsonl

# Sooka endpoints
SOOKA_APP_URL=https://sooka.my
SOOKA_API_BASE_URL=https://api.vr.ctrp.sooka.my
SOOKA_PAIR_TV_URL=https://sooka.my/pair-tv
SOOKA_CONTACT_ENDPOINT=/login/v1/contact
SOOKA_REFRESH_ENDPOINT=/login/auth/v1/refresh-token
SOOKA_VALIDATE_ENDPOINT=/login/v1/smart-tv/validate
SOOKA_STATUS_ENDPOINT=/login/pub/v1/smart-tv/status
SOOKA_TENANT_IDENTIFIER=master
SOOKA_LANGUAGE=eng

# Optional auth bootstrap
# Paste the raw /login response JSON and any extra request headers you want merged into Sooka requests.
SOOKA_ACCESS_TOKEN=
SOOKA_REFRESH_TOKEN=
SOOKA_LOGIN_RESPONSE_JSON=
SOOKA_REQUEST_HEADERS_JSON=

# Persistent session store
SOOKA_SESSION_STORE_FILE=.data/sooka-session.json

# Status polling behavior
SOOKA_STATUS_POLL_INTERVAL_MS=1800
SOOKA_STATUS_TIMEOUT_MS=90000
SOOKA_STATUS_SUCCESS_REGEX=paired|success|linked|activated
SOOKA_STATUS_FAILURE_REGEX=failed|invalid|expired|denied|forbidden|error

# NTFY Notifications (Optional)
# If configured, success and failure notifications will be sent to ntfy.sh
NTFY_TOPIC=
NTFY_URL=https://ntfy.sh
NTFY_TOKEN=
